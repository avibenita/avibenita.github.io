<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
           xsi:type="TaskPaneApp">

  <!-- Manifest ID - Generate a new GUID for your add-in -->
  <Id>c627acf3-c606-4652-ac9f-b25a9c8b71e1</Id>

  <!-- Version -->
  <Version>1.0.0.5</Version>

  <!-- Provider Name -->
  <ProviderName>Your Organization</ProviderName>

  <!-- Default Locale -->
  <DefaultLocale>en-US</DefaultLocale>

  <!-- Display Name -->
  <DisplayName DefaultValue="Statistico Analytics" />

  <!-- Description -->
  <Description DefaultValue="Advanced statistical analysis tools for Excel with guided workflows" />

  <!-- Icon URL - Replace with your icon -->
  <IconUrl DefaultValue="https://statistico.live/statistico-analytics/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://statistico.live/statistico-analytics/assets/icon-64.png" />

  <!-- Support URL -->
  <SupportUrl DefaultValue="https://github.com/avibenita/statistico-analytics" />

  <!-- Hosts -->
  <Hosts>
    <Host Name="Workbook" />
  </Hosts>

  <!-- Default Settings -->
  <DefaultSettings>
    <SourceLocation DefaultValue="https://statistico.live/statistico-analytics/taskpane/workspace-hub.html" />
  </DefaultSettings>

  <!-- Permissions -->
  <Permissions>ReadWriteDocument</Permissions>

  <!-- Version Overrides -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    
    <Hosts>
      <Host xsi:type="Workbook">
        
        <!-- Host Configuration -->
        <DesktopFormFactor>
          
          <!-- Function File -->
          <GetStarted>
            <Title resid="GetStarted.Title"/>
            <Description resid="GetStarted.Description"/>
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl"/>
          </GetStarted>

          <!-- Taskpane Button -->
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="StatisticoGroup">
                <Label resid="StatisticoGroup.Label" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16" />
                  <bt:Image size="32" resid="Icon.32x32" />
                  <bt:Image size="80" resid="Icon.80x80" />
                </Icon>

                <!-- Ribbon menu: hub + direct module task panes (see taskpane/modules.config.json → ribbonMenu) -->
                <Control xsi:type="Menu" id="Statistico.MainMenu">
                  <Label resid="StatisticoMenu.Label" />
                  <Supertip>
                    <Title resid="StatisticoMenu.SupertipTitle" />
                    <Description resid="StatisticoMenu.SupertipDescription" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Items>
                    <Item id="Statistico.ItemHub">
                      <Label resid="Ribbon.Hub.Label" />
                      <Supertip>
                        <Title resid="Ribbon.Hub.Label" />
                        <Description resid="Ribbon.Hub.Tooltip" />
                      </Supertip>
                      <Icon>
                        <bt:Image size="16" resid="Icon.16x16" />
                        <bt:Image size="32" resid="Icon.32x32" />
                        <bt:Image size="80" resid="Icon.80x80" />
                      </Icon>
                      <Action xsi:type="ShowTaskpane">
                        <TaskpaneId>statistico-hub</TaskpaneId>
                        <SourceLocation resid="Taskpane.Url" />
                        <RequestedWidth>400</RequestedWidth>
                      </Action>
                    </Item>
                    <Item id="Statistico.ItemCluster">
                      <Label resid="Ribbon.Cluster.Label" />
                      <Supertip>
                        <Title resid="Ribbon.Cluster.Label" />
                        <Description resid="Ribbon.Cluster.Tooltip" />
                      </Supertip>
                      <Icon>
                        <bt:Image size="16" resid="Icon.16x16" />
                        <bt:Image size="32" resid="Icon.32x32" />
                        <bt:Image size="80" resid="Icon.80x80" />
                      </Icon>
                      <Action xsi:type="ShowTaskpane">
                        <TaskpaneId>statistico-cluster</TaskpaneId>
                        <SourceLocation resid="Taskpane.Url.Cluster" />
                        <RequestedWidth>400</RequestedWidth>
                      </Action>
                    </Item>
                    <Item id="Statistico.ItemPca">
                      <Label resid="Ribbon.Pca.Label" />
                      <Supertip>
                        <Title resid="Ribbon.Pca.Label" />
                        <Description resid="Ribbon.Pca.Tooltip" />
                      </Supertip>
                      <Icon>
                        <bt:Image size="16" resid="Icon.16x16" />
                        <bt:Image size="32" resid="Icon.32x32" />
                        <bt:Image size="80" resid="Icon.80x80" />
                      </Icon>
                      <Action xsi:type="ShowTaskpane">
                        <TaskpaneId>statistico-pca</TaskpaneId>
                        <SourceLocation resid="Taskpane.Url.Pca" />
                        <RequestedWidth>400</RequestedWidth>
                      </Action>
                    </Item>
                  </Items>
                </Control>

              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <!-- Resources -->
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://statistico.live/statistico-analytics/assets/icon-16.png" />
        <bt:Image id="Icon.32x32" DefaultValue="https://statistico.live/statistico-analytics/assets/icon-32.png" />
        <bt:Image id="Icon.80x80" DefaultValue="https://statistico.live/statistico-analytics/assets/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="https://github.com/avibenita/statistico-analytics" />
        <bt:Url id="Taskpane.Url" DefaultValue="https://statistico.live/statistico-analytics/taskpane/workspace-hub.html" />
        <bt:Url id="Taskpane.Url.Cluster" DefaultValue="https://statistico.live/statistico-analytics/taskpane/cluster/cluster.html" />
        <bt:Url id="Taskpane.Url.Pca" DefaultValue="https://statistico.live/statistico-analytics/taskpane/pca/pca.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title" DefaultValue="Statistico Analytics" />
        <bt:String id="StatisticoGroup.Label" DefaultValue="Analytics" />
        <bt:String id="StatisticoMenu.Label" DefaultValue="Statistico" />
        <bt:String id="StatisticoMenu.SupertipTitle" DefaultValue="Statistico Analytics" />
        <bt:String id="Ribbon.Hub.Label" DefaultValue="Workspace Hub" />
        <bt:String id="Ribbon.Cluster.Label" DefaultValue="Cluster Analysis" />
        <bt:String id="Ribbon.Pca.Label" DefaultValue="PCA" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="Your Statistico workspace is loaded. Open Statistico on the Home tab to launch app clusters or a module." />
        <bt:String id="StatisticoMenu.SupertipDescription" DefaultValue="Open the workspace hub or jump directly to Cluster Analysis or PCA." />
        <bt:String id="Ribbon.Hub.Tooltip" DefaultValue="Browse app clusters such as Analytics and Calculators." />
        <bt:String id="Ribbon.Cluster.Tooltip" DefaultValue="K-means and hierarchical clustering on your worksheet data." />
        <bt:String id="Ribbon.Pca.Tooltip" DefaultValue="Principal component analysis — model builder and results dashboard." />
      </bt:LongStrings>
    </Resources>

  </VersionOverrides>

</OfficeApp>
